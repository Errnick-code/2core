{
  "schemaVersion": 1,
  "id": "twocore",
  "version": "${version}",
  "name": "2Core",
  "description": "Run a second Fabric server as a separate JVM process. One mod, two roles.",
  "authors": ["Errnick_"],
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "dev.errnicraft.twocore.TwoCoreMod"
      }
    ]
  },
  "mixins": [
    "twocore.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.13.0+kotlin.2.3.20",
    "minecraft": "~1.21.11"
  }
}
